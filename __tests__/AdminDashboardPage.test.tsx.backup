/**
 * @jest-environment jsdom
 */

import { render, screen, waitFor, act } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import AdminDashboardPage from '@/app/admin/page';

// Mock fetch
global.fetch = jest.fn();

// Helper to create Response objects
const createMockResponse = (data: unknown) => ({
  ok: true,
  json: async () => data,
}) as Response;

describe('AdminDashboardPage', () => {
  const mockFetch = fetch as jest.MockedFunction<typeof fetch>;
  const mockUsersData = [
    { id: 1, email: 'user1@test.com', pseudo: 'User1' },
    { id: 2, email: 'user2@test.com', pseudo: 'User2' },
  ];

  const mockLocationsData = [
    { location_id: 1, name: 'Location 1', city: 'Bordeaux' },
    { location_id: 2, name: 'Location 2', city: 'Paris' },
  ];

  const mockReviewsData = [
    { review_id: 1, comment: 'Great place!', rating: 5 },
    { review_id: 2, comment: 'Nice location', rating: 4 },
  ];

  const mockConfirm = jest.fn();
  const mockAlert = jest.fn();

  beforeEach(() => {
    jest.clearAllMocks();
    global.confirm = mockConfirm;
    global.alert = mockAlert;
    mockFetch.mockResolvedValue(
      Promise.resolve({
        ok: true,
        json: async () => mockUsersData,
      } as Response)
    );
    mockConfirm.mockReturnValue(true);
  });

  it('renders admin dashboard with default users tab', async () => {
    render(<AdminDashboardPage />);

    expect(screen.getByText('Gestion des users')).toBeInTheDocument();
    expect(screen.getByText('Utilisateurs')).toBeInTheDocument();
    expect(screen.getByText('Lieux')).toBeInTheDocument();
    expect(screen.getByText('Avis')).toBeInTheDocument();

    await waitFor(() => {
      expect(mockFetch).toHaveBeenCalledWith('/api/admin/users');
    });
  });

  it('displays users data in default tab', async () => {
    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('user1@test.com')).toBeInTheDocument();
      expect(screen.getByText('User1')).toBeInTheDocument();
      expect(screen.getByText('user2@test.com')).toBeInTheDocument();
      expect(screen.getByText('User2')).toBeInTheDocument();
    });
  });

  it('switches to locations tab when clicked', async () => {
    const user = userEvent.setup();
    mockFetch.mockResolvedValueOnce(createMockResponse(mockUsersData));

    render(<AdminDashboardPage />);

    // Wait for initial render
    await waitFor(() => {
      expect(screen.getByText('Gestion des users')).toBeInTheDocument();
    });

    // Mock locations data for when tab is clicked
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockLocationsData,
    });

    const locationsTab = screen.getByText('Lieux');
    await user.click(locationsTab);

    await waitFor(() => {
      expect(screen.getByText('Gestion des locations')).toBeInTheDocument();
      expect(mockFetch).toHaveBeenCalledWith('/api/admin/locations');
    });
  });

  it('switches to reviews tab when clicked', async () => {
    const user = userEvent.setup();
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockUsersData,
    });

    render(<AdminDashboardPage />);

    // Wait for initial render
    await waitFor(() => {
      expect(screen.getByText('Gestion des users')).toBeInTheDocument();
    });

    // Mock reviews data for when tab is clicked
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockReviewsData,
    });

    const reviewsTab = screen.getByText('Avis');
    await user.click(reviewsTab);

    await waitFor(() => {
      expect(screen.getByText('Gestion des reviews')).toBeInTheDocument();
      expect(mockFetch).toHaveBeenCalledWith('/api/admin/reviews');
    });
  });

  it('highlights active tab correctly', async () => {
    const user = userEvent.setup();
    render(<AdminDashboardPage />);

    // Users tab should be active by default
    const usersTab = screen.getByText('Utilisateurs');
    expect(usersTab).toHaveClass('bg-blue-600', 'text-white');

    // Switch to locations tab
    const locationsTab = screen.getByText('Lieux');
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockLocationsData,
    });

    await user.click(locationsTab);

    await waitFor(() => {
      expect(locationsTab).toHaveClass('bg-blue-600', 'text-white');
      expect(usersTab).toHaveClass('bg-white', 'hover:bg-gray-200');
    });
  });

  it('handles empty data arrays', async () => {
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => [],
    });

    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('Aucune donnée à afficher.')).toBeInTheDocument();
    });
  });

  it('handles API error gracefully', async () => {
    const consoleSpy = jest.spyOn(console, 'error').mockImplementation(() => {});
    mockFetch.mockRejectedValueOnce(new Error('API Error'));

    await act(async () => {
      render(<AdminDashboardPage />);
    });

    await waitFor(() => {
      expect(screen.getByText('Aucune donnée à afficher.')).toBeInTheDocument();
    });

    expect(consoleSpy).toHaveBeenCalledWith('Error fetching data:', expect.any(Error));
    consoleSpy.mockRestore();
  });

  it('renders table headers correctly for users tab', async () => {
    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('id')).toBeInTheDocument();
      expect(screen.getByText('email')).toBeInTheDocument();
      expect(screen.getByText('pseudo')).toBeInTheDocument();
      expect(screen.getByText('Actions')).toBeInTheDocument();
    });
  });

  it('renders table headers correctly for locations tab', async () => {
    const user = userEvent.setup();
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockUsersData,
    });

    render(<AdminDashboardPage />);

    // Wait for initial render
    await waitFor(() => {
      expect(screen.getByText('Gestion des users')).toBeInTheDocument();
    });

    // Mock locations data for when tab is clicked
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockLocationsData,
    });

    const locationsTab = screen.getByText('Lieux');
    await user.click(locationsTab);

    await waitFor(() => {
      expect(screen.getByText('location id')).toBeInTheDocument();
      expect(screen.getByText('name')).toBeInTheDocument();
      expect(screen.getByText('city')).toBeInTheDocument();
      expect(screen.getByText('Actions')).toBeInTheDocument();
    });
  });

  it('renders table headers correctly for reviews tab', async () => {
    const user = userEvent.setup();
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockUsersData,
    });

    render(<AdminDashboardPage />);

    // Wait for initial render
    await waitFor(() => {
      expect(screen.getByText('Gestion des users')).toBeInTheDocument();
    });

    // Mock reviews data for when tab is clicked
    mockFetch.mockResolvedValueOnce({
      ok: true,
      json: async () => mockReviewsData,
    });

    const reviewsTab = screen.getByText('Avis');
    await user.click(reviewsTab);

    await waitFor(() => {
      expect(screen.getByText('review id')).toBeInTheDocument();
      expect(screen.getByText('comment')).toBeInTheDocument();
      expect(screen.getByText('rating')).toBeInTheDocument();
      expect(screen.getByText('Actions')).toBeInTheDocument();
    });
  });

  it('calls edit function when edit button is clicked', async () => {
    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('user1@test.com')).toBeInTheDocument();
    });

    const editButtons = screen.getAllByText('Éditer');
    await userEvent.setup().click(editButtons[0]);

    expect(mockAlert).toHaveBeenCalledWith('Éditer 1');
  });

  it('calls delete function when delete button is clicked', async () => {
    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('user1@test.com')).toBeInTheDocument();
    });

    const deleteButtons = screen.getAllByText('Supprimer');
    await userEvent.setup().click(deleteButtons[0]);

    expect(mockConfirm).toHaveBeenCalledWith('Confirmer la suppression ?');
    expect(mockFetch).toHaveBeenCalledWith('/api/admin/users/1', {
      method: 'DELETE',
    });
  });

  it('does not delete when user cancels confirmation', async () => {
    mockConfirm.mockReturnValue(false);

    render(<AdminDashboardPage />);

    await waitFor(() => {
      expect(screen.getByText('user1@test.com')).toBeInTheDocument();
    });

    const deleteButtons = screen.getAllByText('Supprimer');
    await userEvent.setup().click(deleteButtons[0]);

    expect(mockConfirm).toHaveBeenCalledWith('Confirmer la suppression ?');
    // Should not call the delete API
    expect(mockFetch).not.toHaveBeenCalledWith('/api/admin/users/1', {
      method: 'DELETE',
    });
  });

  it('has correct layout structure', () => {
    render(<AdminDashboardPage />);

    const container = screen.getByText('Utilisateurs').closest('div');
    expect(container).toHaveClass('flex', 'h-screen');
    
    const sidebar = screen.getByText('Utilisateurs').closest('aside');
    expect(sidebar).toHaveClass('w-64', 'bg-gray-100', 'border-r');
    
    const main = screen.getByText('Gestion des users').closest('main');
    expect(main).toHaveClass('flex-1', 'p-6', 'overflow-auto');
  });
});
