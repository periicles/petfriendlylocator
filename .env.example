# Postgres
POSTGRES_USER=petuser
POSTGRES_PASSWORD=petpassword
POSTGRES_DB=petdb

# Prisma
DATABASE_URL=postgres://petuser:petpassword@localhost:5432/petdb?schema=public

# Auth.js (NextAuth v5) — URL auto-detected; AUTH_URL optional
AUTH_SECRET=replace-with-a-random-secret

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.replace-with-your-mapbox-token