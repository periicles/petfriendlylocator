    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.30.0",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.0.3",
    "jest-environment-jsdom": "^30.0.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6"
  }
