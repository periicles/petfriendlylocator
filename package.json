    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "mapbox-gl": "^3.13.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
