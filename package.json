    "@prisma/client": "^6.10.1",
    "@prisma/extension-accelerate": "^2.0.1",
    "autoprefixer": "^10.4.21",
    "mapbox-gl": "^3.13.0",
    "next": "15.3.4",
    "next-auth": "^4.24.11",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.30.0",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "prettier": "^3.6.2",
    "prisma": "^6.10.1",
    "tailwindcss": "4.1",
    "typescript": "^5"
  }
