{
  "name": "petfriendlylocator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "linter": "next lint",
    "lint": "eslint . --ext js,ts,jsx,tsx",
